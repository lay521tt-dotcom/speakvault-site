# SpeakVault Vercel environment variables for Claude / Anthropic
# Copy these into Vercel Project Settings -> Environment Variables,
# or import this file in Vercel if the dashboard offers an env-file import.

# Required: server-side Anthropic API key. Never expose this in frontend code.
ANTHROPIC_API_KEY=

# Required: shared access code for family/friends to use AI feedback.
SPEAKVAULT_ACCESS_CODE=

# Optional: model used by api/analyze-writing.js.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: keep the default unless you use an Anthropic-compatible gateway.
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
