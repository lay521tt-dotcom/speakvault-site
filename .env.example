# SpeakVault Vercel environment variables
# Copy these into Vercel Project Settings -> Environment Variables,
# or import this file in Vercel if the dashboard offers an env-file import.

# Required: server-side OpenAI API key. Never expose this in frontend code.
OPENAI_API_KEY=

# Required: shared access code for family/friends to use AI feedback.
SPEAKVAULT_ACCESS_CODE=

# Optional: model used by api/analyze-writing.js.
OPENAI_MODEL=gpt-4.1-mini
